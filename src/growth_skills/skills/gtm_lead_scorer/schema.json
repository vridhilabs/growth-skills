{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GTM Lead Scorer",
  "description": "Input/output schema for the GTM Lead Scorer skill",
  "input": {
    "type": "object",
    "required": ["name", "title", "company", "source"],
    "properties": {
      "name": { "type": "string", "description": "Full name of the lead" },
      "title": { "type": "string", "description": "Job title at current company" },
      "company": { "type": "string", "description": "Company name" },
      "company_size": { "type": "string", "description": "Estimated headcount e.g. '50-200'" },
      "industry": { "type": "string", "description": "Industry vertical" },
      "source": {
        "type": "string",
        "enum": ["linkedin", "email", "ad", "referral", "inbound", "other"],
        "description": "How the lead entered your pipeline"
      },
      "behavior_signals": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of observed actions e.g. ['opened email 3x', 'visited pricing page']"
      }
    }
  },
  "output": {
    "type": "object",
    "properties": {
      "score": { "type": "integer", "minimum": 0, "maximum": 100 },
      "icp_fit": { "type": "string", "enum": ["strong", "moderate", "weak"] },
      "intent_level": { "type": "string", "enum": ["high", "medium", "low"] },
      "next_action": { "type": "string", "enum": ["demo", "nurture", "disqualify", "watch"] },
      "reasoning": { "type": "string" },
      "crm_tags": { "type": "array", "items": { "type": "string" } }
    }
  },
  "crm_mapping": {
    "twenty_crm": {
      "score": "opportunity.custom_fields.lead_score",
      "next_action": "opportunity.stage",
      "crm_tags": "opportunity.tags"
    }
  }
}
